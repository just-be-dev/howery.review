{
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "name": "howery-review",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "send_email": [
    {
      "name": "EMAIL",
    },
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "howery-review-attachments",
    },
  ],
}
