---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Howery's Review</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Special+Elite&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" type="application/rss+xml" title="Howery's Review" href="/rss" />
    <style is:global>
      :root {
        --paper: #f5ecd7;
        --paper-dark: #e8dcc6;
        --ink: #1a1a1a;
        --red: #b91c1c;
        --red-dark: #7f1d1d;
        --gold: #b8860b;
        --gold-light: #daa520;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Libre Baskerville", "Georgia", serif;
        background: var(--paper);
        color: var(--ink);
        min-height: 100vh;
        line-height: 1.7;
        background-image:
          url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      }

      .site-header {
        text-align: center;
        padding: 2rem 1rem 1rem;
        border-bottom: 4px double var(--red);
        margin-bottom: 2rem;
        position: relative;
      }

      .site-header::before,
      .site-header::after {
        content: "★";
        color: var(--red);
        font-size: 1.2rem;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
      }

      .site-header::before {
        left: 2rem;
      }

      .site-header::after {
        right: 2rem;
      }

      .site-title {
        font-family: "Playfair Display", serif;
        font-weight: 900;
        font-size: clamp(2.5rem, 8vw, 5rem);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--red-dark);
        text-shadow: 2px 2px 0 var(--gold);
        line-height: 1;
      }

      .site-title a {
        color: inherit;
        text-decoration: none;
      }

      .site-subtitle {
        font-family: "Special Elite", cursive;
        font-size: 1rem;
        color: var(--gold);
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-top: 0.5rem;
      }

      .container {
        max-width: 52rem;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
      }

      a {
        color: var(--red);
        text-decoration-style: wavy;
        text-underline-offset: 3px;
      }

      a:hover {
        color: var(--red-dark);
      }

      .rss-link {
        display: inline-block;
        margin-top: 0.75rem;
        color: var(--gold);
        text-decoration: none;
        transition: transform 0.2s, color 0.2s;
      }

      .rss-link svg {
        display: block;
      }

      .rss-link:hover {
        color: var(--red);
        transform: scale(1.2);
      }

      .nav-links {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        margin-top: 0.75rem;
      }

      .nav-link {
        font-family: "Special Elite", cursive;
        font-size: 0.8rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        text-decoration: none;
        transition: color 0.2s;
      }

      .nav-link:hover {
        color: var(--red);
      }

      .site-footer {
        text-align: center;
        padding: 2rem 1rem;
        border-top: 4px double var(--red);
        margin-top: 3rem;
        font-family: "Special Elite", cursive;
        font-size: 0.85rem;
        color: var(--gold);
        letter-spacing: 0.15em;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1 class="site-title"><a href="/">Howery's Review</a></h1>
      <p class="site-subtitle">Motion Picture Critiques & Commentary</p>
      <nav class="nav-links">
        <a href="/guestbook" class="nav-link">&#9829; Guestbook</a>
        <a href="/rss" class="rss-link" title="Subscribe to RSS feed">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
        </a>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      &copy; Howery's Review &bull; All Rights Reserved
    </footer>
  </body>
</html>
